# این فایل را کپی کرده و به نام .env ذخیره کنید، سپس مقادیر واقعی را وارد کنید.
# فایل .env هرگز نباید commit شود (در .gitignore قرار دارد).

# یک کلید تصادفی و طولانی برای جنگو بسازید، مثلاً با:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# در محیط توسعه True، در پروداکشن حتماً False
DJANGO_DEBUG=True

# لیست دامنه‌های مجاز جدا شده با کاما
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# در پروداکشن False بگذارید و فقط دامنه‌های مشخص را در CORS_ALLOWED_ORIGINS بدهید
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=http://localhost:3000

# اطلاعات اتصال دیتابیس MySQL
DB_NAME=Full_Stack
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password-here

# آدرس فرانت‌اند برای ساخت لینک‌های ایمیل (تایید ایمیل، فراموشی رمز)
FRONTEND_URL=http://localhost:3000
